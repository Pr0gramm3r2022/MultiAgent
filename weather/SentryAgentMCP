# requirements:
# pip install llama-index-tools-mcp llama-index-core llama-index-llms-openai

import asyncio
from llama_index.tools.mcp import BasicMCPClient, McpToolSpec
from llama_index.core.agent.workflow import FunctionAgent, ToolCallResult, ToolCall
from llama_index.core.workflow import Context
from llama_index.llms.openai import OpenAI  # swap for any llama-index LLM


# ── Option A: Remote hosted server (recommended) ─────────────────────────────
# Sentry runs a managed MCP server at https://mcp.sentry.dev/mcp
# It uses OAuth — your HTTP client must supply a valid access token.
# Generate one at: sentry.io → Settings → User Auth Tokens
# Required scopes: org:read  project:read  event:read

SENTRY_ACCESS_TOKEN = "sntryu_..."   # your Sentry user auth token

mcp_client = BasicMCPClient(
    "https://mcp.sentry.dev/mcp",
    headers={"Authorization": f"Bearer {SENTRY_ACCESS_TOKEN}"},
)

# ── Option B: Local stdio transport (self-hosted Sentry or offline dev) ───────
# Requires Node.js and @sentry/mcp-server installed globally:
#   npm install -g @sentry/mcp-server
#
# mcp_client = BasicMCPClient(
#     "npx",
#     args=["@sentry/mcp-server"],
#     env={
#         "SENTRY_ACCESS_TOKEN": "sntryu_...",
#         "SENTRY_HOST": "sentry.example.com",   # omit for sentry.io
#     },
# )


# ── Tool spec ─────────────────────────────────────────────────────────────────
mcp_tool_spec = McpToolSpec(
    client=mcp_client,
    # Optionally restrict which Sentry tools the agent can call:
    # allowed_tools=[
    #     "list_issues",
    #     "get_issue",
    #     "search_issues",
    #     "list_projects",
    # ],
)


# ── Agent factory ─────────────────────────────────────────────────────────────
async def build_agent() -> tuple[FunctionAgent, Context]:
    tools = await mcp_tool_spec.to_tool_list_async()

    llm = OpenAI(model="gpt-4o")   # or Anthropic / Gemini / etc.

    agent = FunctionAgent(
        name="SentryAgent",
        description="An agent that queries Sentry for errors, issues, and project data.",
        tools=tools,
        llm=llm,
        system_prompt=(
            "You are a debugging assistant with access to Sentry. "
            "Use Sentry tools to look up errors, investigate issues, "
            "and summarize relevant project health information."
        ),
    )

    ctx = Context(agent)
    return agent, ctx


# ── Run loop ──────────────────────────────────────────────────────────────────
async def chat(query: str, agent: FunctionAgent, ctx: Context, verbose: bool = True) -> str:
    handler = agent.run(query, ctx=ctx)

    async for event in handler.stream_events():
        if verbose and isinstance(event, ToolCall):
            print(f"\n→ calling tool: {event.tool_name}  args: {event.tool_kwargs}")
        elif verbose and isinstance(event, ToolCallResult):
            print(f"← result: {event.tool_output}\n")

    return str(await handler)


async def main():
    agent, ctx = await build_agent()

    queries = [
        "List my Sentry projects.",
        "Show me the 5 most recent unresolved issues.",
        "Summarize the stack trace for the latest TypeError in my project.",
    ]

    for q in queries:
        print(f"\nUser: {q}")
        response = await chat(q, agent, ctx)
        print(f"Agent: {response}")


if __name__ == "__main__":
    asyncio.run(main())